{
  "__comment": "EmberVM starter dashboard (M4 D9). Import into Grafana >= 10 with a Prometheus datasource scraping the apiserver and node daemons' /metrics.",
  "title": "EmberVM",
  "uid": "embervm-v01",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Datasource",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Nodes up",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "refId": "A", "expr": "embervm_nodes_up" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Watchdog reaps (1h)",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "refId": "A", "expr": "sum(increase(embervm_watchdog_reaps_total[1h]))" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Engine tick errors (1h)",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "refId": "A", "expr": "sum(increase(embervm_engine_tick_errors_total[1h]))" }]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Proxy requests by result",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(embervm_proxy_requests_total[5m]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Restore latency P50 by tier",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (tier, le) (rate(embervm_restore_seconds_bucket[5m])))",
          "legendFormat": "p50 {{tier}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Restore latency P99 by tier",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (tier, le) (rate(embervm_restore_seconds_bucket[5m])))",
          "legendFormat": "p99 {{tier}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Create latency P50 by path (G4 gate: fast < 500ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (path, le) (rate(embervm_create_seconds_bucket[5m])))",
          "legendFormat": "p50 {{path}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Chunk-store ops",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (op) (rate(embervm_chunk_ops_total[5m]))",
          "legendFormat": "{{op}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Lifecycle transitions",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (from, to) (rate(embervm_lifecycle_transitions_total[5m]))",
          "legendFormat": "{{from}} → {{to}}"
        }
      ]
    }
  ]
}
